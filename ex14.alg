algoritmo "ex14"

var
NUM1, NUM2: inteiro

inicio

escreva("Digite o primeiro n·mero: ")
leia(NUM1)
escreva("Digite o segundo n·mero: ")
leia(NUM2)

se NUM1 > NUM2 entao
     escreva("O primeiro n·mero ",NUM1," ķ maior que o segundo",NUM2)
senao
     escreva("O segundo n·mero",NUM2," ķ maior que o primeiro",NUM1)
fimse
 
fimalgoritmo
